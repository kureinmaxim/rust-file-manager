# Copy to .env and fill in. NEVER commit the real .env file.

# Address the app listens on (keep it on localhost behind nginx)
BIND_ADDR=127.0.0.1:8080

# Where uploaded files are stored
UPLOAD_DIR=uploads

# User accounts (bcrypt hashes) and pending invites; include it in backups
USERS_FILE=users.json

# Per-file upload limit, in megabytes (match nginx client_max_body_size)
MAX_FILE_SIZE_MB=200

# Login credentials. Generate the hash with:
#   echo 'your-password' | rust-file-manager hash-password
# IMPORTANT: keep the single quotes around the hash — without them the
# $-sequences inside the hash are expanded as variables and login breaks.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=''

# Session cookie signing key: base64 of >= 64 random bytes. Generate with:
#   openssl rand -base64 64 | tr -d '\n'
# If unset, a random key is used and sessions reset on every restart.
SESSION_SECRET=

# Set to true when serving over HTTPS (recommended in production)
COOKIE_SECURE=false

# Log level (tracing syntax), e.g. info, debug, rust_file_manager=debug
RUST_LOG=info
